VITE_ADMIN_PASSWORD=defina_uma_senha_forte
VITE_ADMIN_API_TOKEN=defina_um_token_para_post_api
VITE_NOTIFY_API_TOKEN=defina_um_token_para_notificacoes
ADMIN_API_TOKEN=defina_o_mesmo_token_no_backend
NOTIFY_API_TOKEN=defina_o_mesmo_token_de_notificacao
WA360_API_KEY=defina_sua_api_key_360dialog
WA360_TO_NUMBER=55DDDNUMERO_DESTINO
WA360_TO_NUMBERS=55DDDNUMERO_DESTINO,55DDDNUMERO_SECUNDARIO
WA360_API_URL=https://waba-v2.360dialog.io/messages
MERCADO_PAGO_ACCESS_TOKEN=defina_o_access_token_do_mercado_pago
STRIPE_SECRET_KEY=defina_a_secret_key_da_stripe
ALLOWED_ORIGIN=https://seu-dominio.vercel.app

# Exemplos de configuracao por tenant (opcional)
# Use o sufixo com o ID do tenant em MAIUSCULO e com "_" no lugar de "-"
# Ex.: tenant "cliente-centro" => ADMIN_API_TOKEN__CLIENTE_CENTRO
# ADMIN_API_TOKEN__FOGAO_A_LENHA=token_especifico_do_tenant
# NOTIFY_API_TOKEN__FOGAO_A_LENHA=token_notificacao_do_tenant
# WA360_API_KEY__FOGAO_A_LENHA=api_key_especifica_do_tenant
# WA360_TO_NUMBER__FOGAO_A_LENHA=55DDDNUMERO_DESTINO
# WA360_TO_NUMBERS__FOGAO_A_LENHA=55DDDNUMERO_DESTINO,55DDDNUMERO_SECUNDARIO
# WA360_API_URL__FOGAO_A_LENHA=https://waba-v2.360dialog.io/messages
# MERCADO_PAGO_ACCESS_TOKEN__FOGAO_A_LENHA=access_token_especifico_do_tenant
# STRIPE_SECRET_KEY__FOGAO_A_LENHA=secret_key_especifica_do_tenant
# ALLOWED_ORIGIN__FOGAO_A_LENHA=https://www.seu-dominio.com.br
